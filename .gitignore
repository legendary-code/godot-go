# go-task checksum cache
.task/

# IDE / agent state
.idea/
# .claude holds local agent settings AND project-internal planning notes.
# Ignore everything by default so user-specific settings don't get committed,
# but explicitly track the planning docs we want preserved across clones.
.claude/*
!.claude/PLAN.md
!.claude/PLAN_EXECUTION.md

# OS
.DS_Store
Thumbs.db

# Stray go build artifacts at module root (e.g. when someone runs
# `go build ./cmd/godot-go-bindgen` instead of `go run`). The toolchain
# emits the binary into the cwd; under cmd/<x>/ they belong to the
# tool source dir, not the repo.
/godot-go-bindgen
/godot-go-bindgen.exe
/godot-go
/godot-go.exe
/smoke
/smoke.exe
# Stray .claude/ dirs from running Claude Code in subdirectories.
**/.claude/
!/.claude/
